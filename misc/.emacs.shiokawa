(package-install 'mmm-mode)
(require 'mmm-mode)
;; (setq mmm-global-mode 'maybe)
(set-face-background 'mmm-default-submode-face nil)
(setq mmm-submode-decoration-level 0)
(global-set-key "\M-qm" 'mmm-mode)

(mmm-add-classes
 '(
   (mmm-md-typescript-mode
    :submode typescript-mode
    :face mmm-code-submode-face
    :front "^```\\(ts\\|typescript\\):?.*$"
    :back "^```$"
    )
   (mmm-md-js2-mode
    :submode js2-mode
    :face mmm-code-submode-face
    :front "^```\(js\|javascript\):?.*$"
    :back "^```$"
    )
   (mmm-md-web-mode
    :submode web-mode
    :face mmm-code-submode-face
    :front "^```\\(html\\|css\\):?.*$"
    :back "^```$"
    )
   (mmm-md-sh-mode
    :submode sh-mode
    :face mmm-code-submode-face
    :front "^```\\(sh\\|bash\\):?.*$"
    :back "^```$"
    )
   (mmm-md-diff-mode
    :submode diff-mode
    :face mmm-code-submode-face
    :front "^```diff:?.*$"
    :back "^```$"
    )
   (mmm-md-json-mode
    :submode json-mode
    :face mmm-code-submode-face
    :front "^```json:?.*$"
    :front "^```json$"
    :back "^```$"
    )
   (mmm-md-yaml-mode
    :submode yaml-mode
    :face mmm-code-submode-face
    :front "^```\\(yaml\\|yml\\):?.*$"
    :back "^```$"
    )
   (mmm-md-py-mode
    :submode python-mode
    :face mmm-code-submode-face
    :front "^```\\(python\\|py\\):?.*$"
    :back "^```$"
    )
   (mmm-ts-lit-html-mode
    :submode web-mode
    :face mmm-code-submode-face
    :front "html`$"
    :back "[^\\]`;?$"
    )
     ))
(mmm-add-mode-ext-class 'gfm-mode nil 'mmm-md-typescript-mode)
(mmm-add-mode-ext-class 'gfm-mode nil 'mmm-md-js2-mode)
(mmm-add-mode-ext-class 'gfm-mode nil 'mmm-md-web-mode)
(mmm-add-mode-ext-class 'gfm-mode nil 'mmm-md-sh-mode)
(mmm-add-mode-ext-class 'gfm-mode nil 'mmm-md-diff-mode)
(mmm-add-mode-ext-class 'gfm-mode nil 'mmm-md-json-mode)
(mmm-add-mode-ext-class 'gfm-mode nil 'mmm-md-yaml-mode)
(mmm-add-mode-ext-class 'gfm-mode nil 'mmm-md-py-mode)
(mmm-add-mode-ext-class 'typescript-mode nil 'mmm-ts-lit-html-mode)
