;; --full-time
(setq dired-listing-switches "-lah")
(add-hook 'dired-mode-hook
          '(lambda ()
             ;;(require 'sorter)
             (define-key dired-mode-map "\C-m" 'dired-single-buffer)
             (define-key dired-mode-map "E" 'my-ex-open-linux)
             (define-key dired-mode-map "J" 'dired-open-file)
             (define-key dired-mode-map "\C-j" 'dired-open-file)
             (define-key dired-mode-map "j" 'next-line)
             (define-key dired-mode-map "k" 'previous-line)
             (define-key dired-mode-map "z" 'my-gzip-size)
             ;; (define-key dired-mode-map "t" 'my-copy-template)
             (define-key dired-mode-map "t" 'my-tree)
             (define-key dired-mode-map (kbd "C-c !") 'do-shell-and-copy-to-kill-ring)
             (define-key dired-mode-map "r" 'wdired-change-to-wdired-mode)
             (local-unset-key (kbd "M-n"))
             (local-unset-key (kbd "M-p"))
             (local-unset-key (kbd "C-M-n"))
             (local-unset-key (kbd "C-M-p"))
             (setq truncate-lines t)
             (define-key dired-mode-map "^"
               (function
                (lambda nil (interactive) (dired-single-buffer ".."))))
             )
          )

(defun dired-open-file ()
  "In dired, open the file named on this line."
  (interactive)
  (let* ((file (dired-get-filename nil t)))
    (message "Opening %s..." file)
    (call-process "xdg-open" nil 0 nil file)
    (message "Opening %s done" file)))

(package-install 'wgrep)
(require 'wgrep)
(add-hook 'grep-mode-hook
          '(lambda ()
             (define-key grep-mode-map "r" 'wgrep-change-to-wgrep-mode)
             ))

(defun do-shell-and-copy-to-kill-ring (command &optional arg file-list)
  (interactive
   (let ((files (dired-get-marked-files t current-prefix-arg)))
     (list
      (dired-read-shell-command "! on %s: " current-prefix-arg files)
      current-prefix-arg
      files)))
  (dired-do-shell-command command arg file-list)
  (with-current-buffer "*Shell Command Output*"
    (copy-region-as-kill (point-min) (point-max))))

