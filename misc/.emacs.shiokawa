(set-language-environment "japanese")


(if (eq system-type 'gnu/linux)
  (progn
    (custom-set-faces
      '(show-paren-match ((t (:foreground "black" :background "gray85"))))
      )
    )
  )

(if (version< emacs-version "26.1")
  ()
  (progn
    (setq mouse-drag-and-drop-region 'meta)
    )
  )

(if (eq system-type 'windows-nt)
  (progn
    (set-file-name-coding-system 'shift_jis)
    ;; (setq default-process-coding-system '(shift_jis . shift_jis))
    (custom-set-faces
      '(show-paren-match-face ((t (:foreground "black" :background "grey"))))
      )
    (setq shell-file-name "bash")
    )
  )

(when window-system
  (setq default-frame-alist
    (append '(
               ;; (top                  . 50       ) ;; 配置上位置
               ;; (left                 . 600     ) ;; 配置左位置
               (width                . 120     ) ;; フレーム幅
               (height               . 75     ) ;; フレーム高
               (line-spacing         . 0      ) ;; 文字間隔
               (internal-border-width . 0     ) ;; 余白
               (left-fringe          . 4      ) ;; 左フリンジ幅
               (right-fringe         . 4      ) ;; 右フリンジ幅
               (menu-bar-lines       . nil    ) ;; メニューバー
               (tool-bar-lines       . nil    ) ;; ツールバー
               (vertical-scroll-bars . nil    ) ;; スクロールバー
               (cursor-type          . box    ) ;; カーソル種別
               ;;(foreground-color     . "white") ;; 文字色
               ;;(background-color     . "#393939") ;; 背景色
               ;;(background-color     . "black") ;; 背景色
               ;;(cursor-color         . "red"  ) ;; カーソル色
               ) default-frame-alist) )
  (setq initial-frame-alist default-frame-alist)
