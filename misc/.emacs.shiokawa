(defun lessen-window () (interactive) (enlarge-window -5))
(defun lessen-window-horizontally () (interactive) (enlarge-window-horizontally -5))
(defun enlarge-window-more () (interactive) (enlarge-window 5))
(defun enlarge-window-horizontally-more () (interactive) (enlarge-window-horizontally 5))
