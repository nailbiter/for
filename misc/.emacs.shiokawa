;; (setq-local after-save-hook 'my-plantuml-export)
(defun my-plantuml-export ()
  (interactive)
  (let ((f (substring (buffer-name) 0 -5)))
    (async-shell-command (concat "FILE=" f " && URL=`java -Dfile.encoding=UTF-8 -jar ~/.emacs.d/plantuml.jar -encodeurl ${FILE}.puml` && wget -qO- \"http://www.plantuml.com/plantuml/svg/${URL}\" > ${FILE}.svg && cp ${FILE}.svg ~/Downloads/") "*Plant UML Output*")
    )
  )
(add-to-list 'display-buffer-alist (cons "\\*Plant UML Output\\*.*" (cons #'display-buffer-no-window nil)))


