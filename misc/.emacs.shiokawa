;; C-c s で shell を起動する
;; C-u C-c s で shell を追加起動する
(global-set-key (kbd "C-c s")
                (lambda ()
                  (interactive)
                  (if current-prefix-arg
                      (shell (generate-new-buffer-name "*shell*"))
                    (shell))))
(global-set-key (kbd "C-c 2") (lambda () (interactive) (if (get-buffer "*shell*<2>") (switch-to-buffer "*shell*<2>") (shell (generate-new-buffer "*shell*<2>")))))
(global-set-key (kbd "C-c 3") (lambda () (interactive) (if (get-buffer "*shell*<3>") (switch-to-buffer "*shell*<3>") (shell (generate-new-buffer "*shell*<3>")))))
(global-set-key (kbd "C-c 4") (lambda () (interactive) (if (get-buffer "*shell*<4>") (switch-to-buffer "*shell*<4>") (shell (generate-new-buffer "*shell*<4>")))))
(global-set-key (kbd "C-c 5") (lambda () (interactive) (if (get-buffer "*shell*<5>") (switch-to-buffer "*shell*<5>") (shell (generate-new-buffer "*shell*<5>")))))

