(defun my-tree ()
  (interactive)
  (tree (expand-file-name dired-directory))
  (goto-char 1)
)

(defun my-gzip-size ()
  (interactive)
  (shell-command (concat "gzip -c " (dired-get-filename) " | wc -c | numfmt --to=iec-i"))
)

(defun my-copy-template ()
  (interactive)
  (shell-command (concat "rsync -a " (read-file-name "Enter file name:" "~/.ghq/github.fork.co.jp/junji/dotfiles/templates/") " ./ --exclude node_modules --exclude .git"))
)

(defun my-ex-open-linux ()
  (interactive)
  ;; (start-process " *filer*" nil "nautilus" (expand-file-name dired-directory))
  (start-process " *filer*" nil "thunar" (expand-file-name dired-directory))
  )

(defun my-ex-open-by-windows ()
  (interactive)
  (let ((dname dired-directory))
    (call-process "cmd.exe" nil 0 nil "/c" "start" (replace-regexp-in-string "/" "\\\\" (replace-regexp-in-string "/mnt/c/" "c:/" (replace-regexp-in-string "~" "c:/Users/junji" dname))))
    )
)

