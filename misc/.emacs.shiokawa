;; for bash on Windows
;;(setq visible-cursor t)
(menu-bar-mode 0)
(setenv "LANG" "C")

(setq frame-background-mode 'light)

(setq system-time-locale "C")
(line-number-mode t)
(column-number-mode t)
(blink-cursor-mode 0)
(temp-buffer-resize-mode 0)
;;(setq resize-mini-windows 'grow-only)
(delete-selection-mode t)
(setq display-time-day-and-date t)
(setq display-time-format "%Y-%m-%d (%a) W%V %R")
(setq calendar-week-start-day 1
      calendar-intermonth-text
        '(propertize
          (format "%02d"
                  (car
                   (calendar-iso-from-absolute
                    (calendar-absolute-from-gregorian (list month day year)))))
          'font-lock-face 'font-lock-function-name-face))
(add-hook 'today-visible-calendar-hook 'calendar-mark-today)

(setq mark-holidays-in-calendar t)
(display-time-mode t)
(setq inhibit-startup-message t)
(setq make-backup-files nil)
(setq create-lockfiles nil)
(setq auto-save-default nil)
(setq read-file-name-completion-ignore-case t)
(setq read-buffer-completion-ignore-case t)
(put 'narrow-to-region 'disabled nil)
(put 'narrow-to-page 'disabled nil)
(setq next-line-add-newlines nil)
(setq indent-line-function 'indent-to-left-margin)
(setq kill-whole-line t)
(setq-default dabbrev-case-fold-search t)
(setq-default case-fold-search t)
(setq case-fold-search t)
(setq case-replace-search t)
(setq diff-switches "-u")
;; ediffで別ウィンドウにしない
(setq ediff-window-setup-function 'ediff-setup-windows-plain)
(global-font-lock-mode t)
(global-subword-mode 1)
(setq-default indent-tabs-mode nil)
(setq default-tab-width 2)
(setq tab-width 2)
(auto-compression-mode)
(set-default 'truncate-lines nil)
(show-paren-mode 1)
(setq show-paren-style 'mixed)
(fset 'yes-or-no-p 'y-or-n-p)
(setq default-file-modes 'text-mode)
(setq line-move-visual nil)
(setq page-delimiter "-----")
;;(setq debug-on-error nil)
(setq set-mark-command-repeat-pop t)
(setq ffap-pass-wildcards-to-dired t)
(setq split-width-threshold 300)
(global-set-key "\C-x\C-f" 'find-file-at-point)

(defun next-word (&optional n)
  (interactive "p")
  (and (forward-word (1+ n)) (backward-word 1)))
(global-set-key "\M-f" 'next-word)

(setq shell-command-dont-erase-buffer t)

;; (global-hl-line-mode)
