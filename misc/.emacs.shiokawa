(defun indent-and-next-line () (interactive) (indent-according-to-mode) (next-line 1))
(defun eval-region-with-message () (interactive) (let ()
  (eval-region (region-beginning) (region-end))
  (deactivate-mark)
  (message "eval-region...end")
  ))
(defun insert-time ()
  "insert date string"
  (interactive)
  ;;(call-process "/c/cygwin/bin/date.exe" nil t nil "+%Y/%m/%d %H:%M")
  ;; (call-process "date" nil t nil "+%y%m%d")
  ;; (delete-char -1)
  (insert (format-time-string "%y%m%d"))
  )
(define-key global-map "\C-^" 'insert-time)
(defun insert-todo ()
  "insert todo string"
  (interactive)
  (insert "- [ ] ")
  )
(define-key global-map (kbd "C-\-") 'insert-todo)
(defun dired-template-dir ()
  "open template directory"
  (interactive)
  (dired "~/.ghq/github.fork.co.jp/junji/dotfiles/templates/")
  )
(global-set-key "\M-qi" 'dired-template-dir)


